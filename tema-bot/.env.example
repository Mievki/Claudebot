# ===== Uitvoeringsmodus =====
# paper = lokale simulatie met echte prijzen (GEEN orders, nul risico) -> begin hier
# demo  = OKX demo trading (nep-geld, echte API)  -> stap 2
# live  = echt geld (vereist ALLOW_LIVE=1)         -> pas als laatste
MODE=paper

# ===== OKX API (alleen nodig voor demo/live) =====
# Demo-keys maak je in OKX onder "Demo Trading". Live-keys onder je echte account.
# Geef de key ALLEEN spot-trade-rechten, GEEN withdraw-rechten. Beperk op IP.
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
BASE_URL=https://www.okx.com

# ===== Strategie (MATCHT je gevalideerde backtest — niet zomaar wijzigen) =====
INST_ID=BTC-USDT
BAR=1Dutc
TEMA_LEN=120
CMO_WIN=14
CMO_TRIGGER=10
ATR_WIN=14
ATR_MULT=3.5
VOL_WIN=30
TARGET_VOL=0.40
F_MIN=0.10
F_MAX=1.0
# Warmup-historie: ewm(adjust=False) hangt af van het startpunt. Bij 400 bars wijkt
# TEMA(120) ~$118 af van de backtest; bij 1200 bars <$0.001 (zie tests/test_parity.py).
HIST_BARS=1200

# ===== Geld & veiligheid =====
START_EQUITY=1000
# Paper-kosten = backtest-aannames (0,2% fee per kant, 0,1% slippage).
# NB: paper rekent slippage op beide kanten; backtest alleen op stop-exits (conservatiever).
PAPER_FEE=0.002
PAPER_SLIP=0.001
ALLOW_LIVE=0
MAX_LIVE_EQUITY=100
